# Force GitHub to detect C++ as the main language

# Mark source code files as C++ and force detection
*.cpp linguist-language=C++ linguist-detectable=true
*.hpp linguist-language=C++ linguist-detectable=true

# Mark header files as C++ (not vendored)
*.h   linguist-language=C++ linguist-detectable=true

# Exception: known third-party single-header libraries - mark as vendored
demo/stb_image.h linguist-vendored=true
demo/glut.h      linguist-vendored=true
demo/glaux.h     linguist-vendored=true
demo/iGraphics.h linguist-vendored=false
demo/iGraphics.h linguist-detectable=true

# Mark all binary and asset files as vendored (ignored in language stats)
*.dll  linguist-vendored=true
*.lib  linguist-vendored=true
*.LIB  linguist-vendored=true
*.wav  linguist-vendored=true
*.WAV  linguist-vendored=true
*.png  linguist-vendored=true
*.jpg  linguist-vendored=true
*.PNG  linguist-vendored=true
*.JPG  linguist-vendored=true
