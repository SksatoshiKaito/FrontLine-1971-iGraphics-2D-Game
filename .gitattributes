# Linguist overrides for GitHub language detection

# Mark binary and asset files as vendored (excluded from language stats)
*.dll  linguist-vendored=true
*.lib  linguist-vendored=true
*.LIB  linguist-vendored=true
*.wav  linguist-vendored=true
*.WAV  linguist-vendored=true
*.png  linguist-vendored=true
*.jpg  linguist-vendored=true
*.PNG  linguist-vendored=true
*.JPG  linguist-vendored=true

# Mark known third-party headers as vendored
demo/stb_image.h linguist-vendored=true
demo/glut.h      linguist-vendored=true
demo/glaux.h     linguist-vendored=true
demo/glui32.lib  linguist-vendored=true
demo/bitmap_loader.h linguist-vendored=true
